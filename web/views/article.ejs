<h1><%= pageMenu.name %></h1>
<% articles.forEach(a => { %>
  <div style="margin-bottom:20px;">
    
    <h2><%= lang === 'en' ? a.title_en : a.title_hu %></h2>

    <p><%- lang === 'en' ? a.content_en : a.content_hu %></p>
  
    <small style="display:block; margin-top:10px;">
      <%= settings.admin_user %><br>
      <%= a.created_at %>
    </small>
        <% if (user && user.username) { %>

    <a href="/admin/articles/load/<%= a.id %>"><%= lang === 'en' ? 'Edit' : 'Szerkeszt√©s' %></a>


    <form method="POST"
          action="/admin/articles/delete/<%= a.id %>"
          class="js-confirm-delete"
          data-message="<%= lang === 'en'
            ? 'Are you sure you want to delete this article?'
            : 'Biztos t√∂rl√∂d ezt a cikket?' %>">
          <button type="submit">
              <%= lang === 'en' ? 'Delete' : 'T√∂rl√©s' %>
          </button>
    </form>

      <% } %>
  </div>
<% }) %>
<% if (user && user.username) { %>
  <script src="/public/js/delete.js" defer></script>
<% } %>
