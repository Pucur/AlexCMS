<h1><%= lang === 'en' ? 'Admin - Control Panel' : 'Admin - kezelőpanel' %></h1>

<button id="btnTitle">
  <%= lang === 'en' ? 'Edit site title' : 'Címsor módosítása' %>
</button>

<div id="titleForm" style="display:none; margin-top:10px;">
  <form method="POST" action="/admin/settings/update">
    <input 
      name="site_title" 
      value="<%= site_title || 'AlexCMS' %>" 
      style="width: 300px;"
      placeholder="<%= lang === 'en' ? 'Site title' : 'Oldal címe' %>"
    ><br>
    <button type="submit">
      <%= lang === 'en' ? 'Save' : 'Mentés' %>
    </button>
  </form>
</div>

<button id="btnMenu" style="margin-top:20px;">
  <%= lang === 'en' ? 'Create menu' : 'Menü létrehozása' %>
</button>

<div id="menuForm" style="display:none; margin-top:10px;">
  <form method="POST" action="/admin/menu">
    <input 
      name="name" 
      placeholder="<%= lang === 'en' ? 'Menu name' : 'Menü név' %>"><br>

    <input 
      name="url" 
      placeholder="<%= lang === 'en' ? 'URL (e.g. /news)' : 'URL (pl: /hirek)' %>"><br>

    <select name="type">
      <option value="article"><%= lang === 'en' ? 'Article' : 'Cikk' %></option>
      <option value="download"><%= lang === 'en' ? 'Download' : 'Letöltés' %></option>
      <option value="gallery"><%= lang === 'en' ? 'Gallery' : 'Galéria' %></option>
    </select><br>

    <button type="submit">
      <%= lang === 'en' ? 'Create' : 'Létrehozás' %>
    </button>
  </form>
</div>

<button id="btnSeo" style="margin-top:20px;">
  <%= lang === 'en' ? 'SEO settings' : 'SEO beállítások' %>
</button>
<div id="seoForm" style="display:none; margin-top:10px;">
  <form method="POST" action="/admin/settings/seo">
    
    <label>Meta description</label><br>
    <textarea 
      name="meta_description" 
      style="width:400px; height:80px;"
      placeholder="<%= lang === 'en' ? 'Description' : 'Leírás' %>"><%= meta_description || '' %></textarea><br>

    <label>Meta keywords</label><br>
    <input 
      name="meta_keywords" 
      style="width:400px;"
      placeholder="<%= lang === 'en' ? 'Keywords' : 'Kulcsszavak' %>"
      value="<%= meta_keywords || '' %>"><br><br>

    <button type="submit">
      <%= lang === 'en' ? 'Save' : 'Mentés' %>
    </button>
  </form>
</div>

<button id="btnPassword">
  <%= lang === 'en' ? 'Change password' : 'Jelszó módosítása' %>
</button>

<div id="passwordForm" style="display:none; margin-top:10px;">
  <form method="POST" action="/admin/settings/password">
    
    <input
      type="password"
      name="old_password"
      placeholder="<%= lang === 'en' ? 'Current password' : 'Jelenlegi jelszó' %>"
      required
    ><br>

    <input
      type="password"
      name="new_password"
      placeholder="<%= lang === 'en' ? 'New password' : 'Új jelszó' %>"
      required
    ><br>

    <input
      type="password"
      name="confirm_password"
      placeholder="<%= lang === 'en' ? 'Confirm password' : 'Jelszó megerősítése' %>"
      required
    ><br>

    <button type="submit">
      <%= lang === 'en' ? 'Save' : 'Mentés' %>
    </button>
  </form>
</div>

<hr>

<h2><%= lang === 'en' ? 'Existing menus' : 'Meglévő menük' %></h2>

<% if (menu && menu.length) { %>
  <% menu.forEach(m => { %>

    <div>
      <b><%= m.name %></b> - <%= m.url %> - (<%= m.type %>)

      <a href="/admin/menu/edit/<%= m.id %>">
        <%= lang === 'en' ? 'Edit' : 'Szerkesztés' %>
      </a>

      <form method="POST" action="/admin/menu/delete/<%= m.id %>" style="display:inline;">
<button type="submit"
          class="delete-btn"
          data-confirm="<%= lang === 'en'
            ? 'Are you sure you want to delete this menu and all related content?'
            : 'Biztos törlöd ezt a menüt és a hozzá tartozó tartalmakat?' %>">
            
    <%= lang === 'en' ? 'Delete' : 'Törlés' %>
  </button>
      </form>

      <a href="/admin/menu/up/<%= m.id %>">⬆</a>
      <a href="/admin/menu/down/<%= m.id %>">⬇</a>
    </div>

  <% }) %>
<% } else { %>
  <p><%= lang === 'en' ? 'No menu' : 'Nincs menü' %></p>
<% } %>

<script src="/public/js/admin.js"></script>
